      {% endfor %}
    }
  {% endif %}
{% endfor %}

{% for enum_name, enum_values in symbols.enums.items() %}
  {% if enum_name == 'lore_event_tag_t' %}
    {% for value in enum_values %}
        func (e *LoreEventFFI) as{{pascal_case(value.lower())}}EventDataFFI() *Lore{{pascal_case(value.lower())}}EventDataFFI {
            unionPtr := unsafe.Add(unsafe.Pointer(e), loreEventUnionOffset)
            return (*Lore{{pascal_case(value.lower())}}EventDataFFI)(unionPtr)
        }
    {% endfor %}
  {% endif %}
{% endfor %}

func (e *LoreEventFFI) GetData() any {
    switch e.Tag {
{% for enum_name, enum_values in symbols.enums.items() %}
  {% if enum_name == 'lore_event_tag_t' %}
    {% for value in enum_values %}
        case LoreEventTag_{{value}}:
            return e.as{{pascal_case(value.lower())}}EventDataFFI()
    {% endfor %}
        default:
            return nil
  {% endif %}
{% endfor %}
    }
}

{% for struct_type, struct_fields in symbols.events.items() %}
  {% if struct_type not in custom_types and not struct_type.endswith("_array_t") %}
    func (e *{{ pascal_case(struct_type.removesuffix("_t")) }}FFI) Clone() {{ pascal_case(struct_type.removesuffix("_t")) }} {
        return {{ pascal_case(struct_type.removesuffix("_t")) }}{
            {% for field in struct_fields %}
                {% if field.2 != 0 %}
                    {{pascal_case(field.1)}}:     {{ utils.clone_fixed_array("e." + pascal_case(field.1), pascal_case(field.0.removesuffix("_t")), field.2) }},
                {% elif field.0 == "uint8_t"%}
                    {{pascal_case(field.1)}}:     e.{{pascal_case(field.1)}} != 0,
                {% elif field.0 in cToGoFFITypeMap %}
                    {{pascal_case(field.1)}}:     e.{{pascal_case(field.1)}}.Clone(),
                {% elif field.0 in cTypesThatNeedCustomBuilder %}
                    {{pascal_case(field.1)}}:     e.{{pascal_case(field.1)}}.Clone(),
                {% elif field.0 in symbols.types.keys() and field.0 not in custom_types %}
                    {{pascal_case(field.1)}}:     e.{{pascal_case(field.1)}}.Clone(),
                {% elif field.0.endswith("_event_data_t") or field.0.endswith("_array_t") %}
                    {{pascal_case(field.1)}}:     e.{{pascal_case(field.1)}}.Clone(),
                {% else %}
                    {{pascal_case(field.1)}}:     e.{{pascal_case(field.1)}},
                {% endif %}
            {% endfor %}
