    }
  {% endif %}
{% endfor %}

// Clone creates a Go-native copy of the event data
// This copy is safe to keep after the callback returns
func (e *LoreEventFFI) Clone() LoreEvent {
    switch e.Tag {
{% for enum_name, enum_values in symbols.enums.items() %}
  {% if enum_name == 'lore_event_tag_t' %}
    {% for value in enum_values %}
        case LoreEventTag_{{value}}:
            return LoreEvent{
                Tag: e.Tag,
                Data: e.as{{pascal_case(value.lower())}}EventDataFFI().Clone(),
            }
    {% endfor %}
        default:
            return LoreEvent{                                                                                                                 
                Tag: e.Tag,
            }
  {% endif %}
{% endfor %}
    }
}
